{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "silhouette-scene.schema.json",
  "title": "silhouette-scene props",
  "description": "Character/group silhouettes + background + simple movement.",
  "type": "object",
  "additionalProperties": false,
  "required": ["figures"],
  "properties": {
    "figures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset"],
        "properties": {
          "asset": { "type": "string", "minLength": 1 },
          "action": { "enum": ["static", "walk", "march", "fall", "raise-arm", "point"] },
          "position": { "enum": ["left", "center", "right", "foreground", "background"] }
        }
      }
    },
    "background": { "type": "string", "minLength": 1 },
    "onScreenText": { "type": "string" },
    "aspectRatio": { "enum": ["16:9", "9:16"], "default": "16:9" }
  }
}
