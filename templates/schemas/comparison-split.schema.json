{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "comparison-split.schema.json",
  "title": "comparison-split props",
  "description": "Split screen comparing two states/periods.",
  "type": "object",
  "additionalProperties": false,
  "required": ["left", "right"],
  "properties": {
    "left": { "$ref": "#/definitions/side" },
    "right": { "$ref": "#/definitions/side" },
    "heading": { "type": "string" },
    "aspectRatio": { "enum": ["16:9", "9:16"], "default": "16:9" }
  },
  "definitions": {
    "side": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "image": { "type": "string", "minLength": 1 },
        "value": { "type": "string" },
        "icon": { "type": "string", "minLength": 1 }
      }
    }
  }
}
