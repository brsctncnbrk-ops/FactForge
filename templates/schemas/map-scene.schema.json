{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "map-scene.schema.json",
  "title": "map-scene props",
  "description": "Map + region highlight + icon placement + camera movement.",
  "type": "object",
  "additionalProperties": false,
  "required": ["region", "camera"],
  "properties": {
    "region": { "type": "string", "minLength": 1 },
    "camera": {
      "enum": ["static", "slow-zoom-in", "slow-zoom-out", "slow-pan-left", "slow-pan-right", "drift"]
    },
    "mapAsset": { "type": "string", "minLength": 1 },
    "highlights": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "icons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset", "placement"],
        "properties": {
          "asset": { "type": "string", "minLength": 1 },
          "placement": { "type": "string", "minLength": 1 },
          "label": { "type": "string" }
        }
      }
    },
    "onScreenText": { "type": "string" },
    "aspectRatio": { "enum": ["16:9", "9:16"], "default": "16:9" }
  }
}
