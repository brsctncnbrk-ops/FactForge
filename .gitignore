node_modules/
__pycache__/
*.pyc
.env
.DS_Store
.venv/

# Media outputs — renders stay out of git.
# (Licensed SVG library assets under assets/library/ are text and stay tracked.)
*.mp4
*.mov
*.webm
*.wav
*.mp3
*.m4a
# EXCEPTION: per-video voiceover must stay tracked — the cloud render workflow
# (render.yml) checks out the repo and stages this file; without it the voiced
# render guard fails. Revisit with Git LFS when the library grows (~10 MB/video).
!outputs/*/audio/voiceover.mp3

# Render layer throwaways (also covered by render/.gitignore)
render/out/
render/public/

# Alignment / transcription caches
.whisper-cache/
*.transcript.json
